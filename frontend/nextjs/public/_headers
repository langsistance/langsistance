# Prevent browser + CDN caching of RSC payloads (*.txt).
# These are only meant for Next.js router's internal fetch() calls;
# a stale cached copy can leak raw RSC wire format to the user
# after network interruptions, redirecting the browser to index.txt.
/*.txt
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0
  CDN-Cache-Control: no-store

# Ensure HTML pages are served with the correct charset
/*.html
  Content-Type: text/html; charset=utf-8

